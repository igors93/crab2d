# ─── Rust / Cargo ────────────────────────────────────────────────────────────
/target/
**/target/
**/*.rs.bk
**/*.pdb

# ─── Build artifacts ─────────────────────────────────────────────────────────
dist/
out/
build/

# ─── Editor / IDE ────────────────────────────────────────────────────────────
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains (RustRover, CLion, etc.)
.idea/
*.iml
*.iws
*.ipr

# Helix / Vim / Emacs
.helix/
*.swp
*.swo
*~
\#*\#
.\#*

# ─── OS ──────────────────────────────────────────────────────────────────────
# Linux
.directory
.Trash-*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Game engine / runtime ───────────────────────────────────────────────────
# Generated / cached assets
assets/cache/
assets/.cache/
*.asset.meta
*.import

# Compiled shaders cache
shaders/cache/
**/*.spv.cache

# Save files and user data created at runtime
saves/
userdata/
*.sav

# Log files
logs/
*.log
*.log.*

# Crash dumps
*.dmp
crash_reports/

# Profiling data
*.perf
*.trace
flamegraph*.svg
perf.data
perf.data.old
callgrind.out.*
cachegrind.out.*

# ─── Environment / secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets/

# ─── AI provider keys — NEVER commit these ───────────────────────────────────
# Keys are saved to ~/.config/crab2d/ai_config.json (outside the repo).
# These patterns catch any key file that might accidentally land here.
ai_config.json
ai_config.toml
*.apikey
*_api_key.txt
*_api_key.json

# ─── Docs build ──────────────────────────────────────────────────────────────
docs/book/
docs/api/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
